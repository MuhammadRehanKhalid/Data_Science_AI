library(ggplot2)
library(readr)
# =============================
# EXPORT SETTINGS
# =============================
save_figures <- TRUE
show_plots <- FALSE        # TRUE if you want to see them
export_format <- "png"     # png, jpg, svg, pdf, tiff
export_dpi <- 600
output_folder <- "output"
if(!dir.exists(output_folder)){
dir.create(output_folder)
}
# =============================
# LOAD DATA
# =============================
df <- read_csv("Book1.csv")
categories <- df[,1:3]
data <- df[,4:ncol(df)]
num_vars <- ncol(data)/3
cat("Total graphs to generate:", num_vars, "\n")
# =============================
# LOOP
# =============================
for(i in 1:num_vars){
mean_value  <- as.numeric(data[[i*3-2]])
error_value <- as.numeric(data[[i*3-1]])
letters     <- as.character(data[[i*3]])
plot_data <- data.frame(
variety = categories$variety,
stress = categories$stress,
treatment = categories$treatment,
mean_value = mean_value,
error_value = error_value,
letters = letters
)
plot_data$category <- paste(plot_data$variety,
plot_data$stress,
sep="_")
p <- ggplot(plot_data,
aes(x=category,
y=mean_value,
fill=treatment)) +
geom_bar(
stat="identity",
position=position_dodge(width=0.8),
width=0.7,
color="black"
) +
geom_errorbar(
aes(ymin=mean_value-error_value,
ymax=mean_value+error_value),
position=position_dodge(width=0.8),
width=0.2
) +
geom_text(
aes(label=letters,
y=mean_value+error_value),
position=position_dodge(width=0.8),
vjust=-0.5,
size=5
) +
scale_fill_brewer(palette="Set2") +
theme_classic() +
labs(
x="Variety × Stress",
y=colnames(data)[i*3-2],
fill="Treatment"
)
# =============================
# EXPORT
# =============================
if(save_figures){
filename <- paste0(output_folder,"/",
colnames(data)[i*3-2],".",
export_format)
ggsave(
filename,
plot=p,
dpi=export_dpi,
width=8,
height=5
)
cat("Saved:", filename, "\n")
}
# =============================
# SHOW PLOT (OPTIONAL)
# =============================
if(show_plots){
print(p)
}
}
